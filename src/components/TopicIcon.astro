---
interface Props {
  name: "reading" | "health" | "training" | "neuroscience" | "tools" | "resources";
}

const { name } = Astro.props;
---

<span class="topic-icon" aria-hidden="true">
  {name === "reading" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 11.5c4.8-2.6 10-2.6 15.5-.2V37c-5.5-2.4-10.7-2.4-15.5.2z" />
      <path d="M40 11.5c-4.8-2.6-10-2.6-15.5-.2V37c5.5-2.4 10.7-2.4 15.5.2z" />
      <path d="M24 12v25" />
    </svg>
  )}

  {name === "health" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 38s-11-6.8-14.2-14.1C7.7 19.1 10.2 12 16 12c3.3 0 5.8 1.7 8 4.8 2.2-3.1 4.7-4.8 8-4.8 5.8 0 8.3 7.1 6.2 11.9C35 31.2 24 38 24 38z" />
      <path d="M17 24h4l2-4 3 8 2-4h3" />
    </svg>
  )}

  {name === "training" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 18v12" />
      <path d="M12 15v18" />
      <path d="M36 15v18" />
      <path d="M41 18v12" />
      <path d="M12 24h24" />
      <path d="M17 17v14" />
      <path d="M31 17v14" />
    </svg>
  )}

  {name === "neuroscience" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 11c-4.7 0-8 3.6-8 8 0 2.4 1 4.4 2.8 5.8-1.2 1.3-1.8 2.9-1.8 4.7 0 4 2.8 7.5 7.5 7.5 2.3 0 4-1 5.5-2.7 1.5 1.7 3.2 2.7 5.5 2.7 4.7 0 7.5-3.5 7.5-7.5 0-1.8-.6-3.4-1.8-4.7C39 23.4 40 21.4 40 19c0-4.4-3.3-8-8-8-2.7 0-5 1.1-6.5 3.1C24 12.1 21.7 11 19 11z" />
      <path d="M24 15v18" />
      <path d="M17 21h5" />
      <path d="M26 21h5" />
      <path d="M18 29h4" />
      <path d="M26 29h4" />
    </svg>
  )}

  {name === "tools" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 30 31 17" />
      <path d="M30 12a5.5 5.5 0 0 0 6 7L24.5 30.5a5 5 0 1 1-7-7L29 12z" />
      <path d="M14 34l-2 2" />
      <path d="M19 39l-2 2" />
    </svg>
  )}

  {name === "resources" && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 16.5h13l3 3H40v15.5a3 3 0 0 1-3 3H11a3 3 0 0 1-3-3z" />
      <path d="M8 16a3 3 0 0 1 3-3h9l3 3h14a3 3 0 0 1 3 3v1" />
      <path d="M17 25h14" />
      <path d="M17 30h10" />
    </svg>
  )}
</span>
