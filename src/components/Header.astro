---
import { navigation, siteConfig } from "../data/site";
import { withBasePath } from "../lib/paths";

const pathname = Astro.url.pathname;
const searchHref = withBasePath("/search/");

function isActive(href: string) {
  const target = withBasePath(href);
  if (href === "/") {
    return pathname === target;
  }
  return pathname.startsWith(target);
}

const isSearchActive = pathname.startsWith(searchHref);
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href={withBasePath("/")}>{siteConfig.title}</a>

    <div class="site-header__controls">
      <nav class="site-nav" aria-label="顶部导航">
        {navigation.map((item) => (
          <a href={withBasePath(item.href)} class={isActive(item.href) ? "is-active" : undefined}>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="site-header__actions">
        <a
          class:list={["site-search-link", isSearchActive && "is-active"]}
          href={searchHref}
          aria-label="打开站内搜索"
          title="搜索"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="6.5"></circle>
            <path d="M16 16l4.5 4.5"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>
