---
import { formatDate, getCategoryHref, getPostHref, getUpdatedDate } from "../lib/blog";
import { withBasePath } from "../lib/paths";
import type { Post } from "../lib/blog";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const postHref = withBasePath(getPostHref(post));
const categoryHref = withBasePath(getCategoryHref(post.data.category));
const updated = getUpdatedDate(post);
const fallbackLead = post.data.tags.slice(0, 2).join(" / ") || formatDate(updated);
---

<article class="post-card">
  <a class:list={["post-card__media", !post.data.cover && "post-card__media--fallback"]} href={postHref} aria-hidden="true" tabindex="-1">
    {post.data.cover ? (
      <img class="post-card__cover" src={withBasePath(post.data.cover)} alt="" />
    ) : (
      <div class="post-card__cover post-card__cover--fallback">
        <span>{post.data.category}</span>
        <p>{fallbackLead}</p>
      </div>
    )}
  </a>

  <div class="post-card__content">
    <div class="post-card__meta">
      <a href={categoryHref}>{post.data.category}</a>
      <span>{formatDate(post.data.date)}</span>
      <span>更新 {formatDate(updated)}</span>
    </div>
    <h2 class="post-card__title">
      <a href={postHref}>{post.data.title}</a>
    </h2>
    <p class="post-card__description">{post.data.description}</p>
  </div>
</article>
