---
import { formatDate, getCategoryHref, getPostHref } from "../lib/blog";
import type { Post } from "../lib/blog";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="post-card">
  {post.data.cover && (
    <a href={getPostHref(post)}>
      <img class="post-card__cover" src={post.data.cover} alt={post.data.title} />
    </a>
  )}
  <div class="post-card__content">
    <div class="post-card__meta">
      <span>{formatDate(post.data.date)}</span>
      <a href={getCategoryHref(post.data.category)}>{post.data.category}</a>
    </div>
    <h2 class="post-card__title">
      <a href={getPostHref(post)}>{post.data.title}</a>
    </h2>
    <p class="post-card__description">{post.data.description}</p>
  </div>
</article>
