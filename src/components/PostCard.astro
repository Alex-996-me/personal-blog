---
import { formatDate, getCategoryHref, getPostHref } from "../lib/blog";
import { withBasePath } from "../lib/paths";
import type { Post } from "../lib/blog";

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<article class="post-card">
  <div class="post-card__content">
    <div class="post-card__meta">
      <span>{formatDate(post.data.date)}</span>
      <a href={withBasePath(getCategoryHref(post.data.category))}>{post.data.category}</a>
    </div>
    <h2 class="post-card__title">
      <a href={withBasePath(getPostHref(post))}>{post.data.title}</a>
    </h2>
    <p class="post-card__description">{post.data.description}</p>
  </div>
  {post.data.cover && (
    <a class="post-card__media" href={withBasePath(getPostHref(post))} aria-hidden="true" tabindex="-1">
      <img class="post-card__cover" src={withBasePath(post.data.cover)} alt="" />
    </a>
  )}
</article>
