---
import { modules, siteConfig } from "../data/site";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getCategoryCounts,
  getCategoryHref,
  getInspirationHref,
  getPostHref,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations] = await Promise.all([getAllPosts(), getAllInspirations()]);
const recentPosts = posts.slice(0, 5);
const recentInspirations = inspirations.slice(0, 5);
const categoryCounts = getCategoryCounts(posts);
const currentQuery = Astro.url.searchParams.get("q") ?? "";
---

<aside class="sidebar" aria-label="侧栏">
  <section class="sidebar-section">
    <h2>搜索</h2>
    <form class="search-form" action={withBasePath("/search/")} method="get">
      <input type="search" name="q" value={currentQuery} placeholder="搜索标题、正文、标签或资料" />
      <button type="submit">搜索</button>
    </form>
  </section>

  <section class="sidebar-section">
    <h2>关于作者</h2>
    <p>{siteConfig.author.shortBio}</p>
  </section>

  <section class="sidebar-section">
    <h2>栏目</h2>
    <ul class="plain-list">
      {modules.map((module) => (
        <li>
          <a href={withBasePath(module.href)}>{module.name}</a>
          <br />
          <small>{module.description}</small>
        </li>
      ))}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2>最近文章</h2>
    <ul class="plain-list">
      {recentPosts.map((post) => (
        <li>
          <a href={withBasePath(getPostHref(post))}>{post.data.title}</a>
          <br />
          <small>{formatDate(post.data.date)}</small>
        </li>
      ))}
    </ul>
  </section>

  <section class="sidebar-section">
    <h2>最新灵感</h2>
    {recentInspirations.length > 0 ? (
      <ul class="plain-list">
        {recentInspirations.map((inspiration) => (
          <li>
            <a href={withBasePath(getInspirationHref(inspiration))}>{inspiration.data.title}</a>
            <br />
            <small>{formatDate(inspiration.data.date)}</small>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">这里会放短想法、随手记和还没长成文章的念头。</p>
    )}
  </section>

  <section class="sidebar-section">
    <h2>分类</h2>
    <ul class="plain-list">
      {categoryCounts.map((category) => (
        <li>
          <a href={withBasePath(getCategoryHref(category.name))}>
            {category.name}（{category.count}）
          </a>
        </li>
      ))}
    </ul>
  </section>
</aside>
