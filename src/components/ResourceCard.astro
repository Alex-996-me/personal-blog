---
import {
  formatDate,
  getResourceCover,
  getResourceHref,
  getResourcePrimaryFile,
  type ResourceDocument,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

interface Props {
  resource: ResourceDocument;
}

const { resource } = Astro.props;
const resourceHref = withBasePath(getResourceHref(resource));
const coverPath = getResourceCover(resource);
const cover = coverPath ? withBasePath(coverPath) : "";
const primaryFile = getResourcePrimaryFile(resource);
const fileUrl = primaryFile ? withBasePath(primaryFile) : "";
const hasGroupedAssets = (resource.data.groups ?? []).length > 0;
---

<article class="resource-card">
  <a class:list={["post-card__media", !cover && "post-card__media--fallback"]} href={resourceHref} aria-hidden="true" tabindex="-1">
    {cover ? (
      <img class="post-card__cover" src={cover} alt="" />
    ) : (
      <div class="post-card__cover post-card__cover--fallback">
        <span>资料</span>
        <strong>{resource.data.title}</strong>
      </div>
    )}
  </a>

  <div class="resource-card__content">
    <div class="post-card__meta">
      <span>资料</span>
      <span>{formatDate(resource.data.date)}</span>
    </div>
    <h2 class="post-card__title">
      <a href={resourceHref}>{resource.data.title}</a>
    </h2>
    <p class="post-card__description">{resource.data.description}</p>
    {resource.data.tags.length > 0 && (
      <div class="tag-list" aria-label="资料标签">
        {resource.data.tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
    <div class="resource-card__actions">
      <a href={resourceHref}>查看详情</a>
      {hasGroupedAssets ? (
        <a href={resourceHref}>在线浏览</a>
      ) : (
        fileUrl && (
          <a href={fileUrl} target="_blank" rel="noopener noreferrer">
            在线阅读
          </a>
        )
      )}
      {fileUrl && (
        <a href={fileUrl} download>
          下载
        </a>
      )}
    </div>
  </div>
</article>
