---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../data/site";
import { withBasePath } from "../lib/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  showSidebar?: boolean;
  wideContent?: boolean;
  bodyClass?: string;
  shellClass?: string;
  panelClass?: string;
  headerSearch?: boolean;
  headerSearchQuery?: string;
  headerSearchPlaceholder?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage = siteConfig.defaultOgImage,
  showSidebar = true,
  wideContent = false,
  bodyClass = "",
  shellClass = "",
  panelClass = "",
  headerSearch = false,
  headerSearchQuery = "",
  headerSearchPlaceholder = "",
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.title}`;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(withBasePath(ogImage), site).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBasePath("/favicon.svg")} />
    <link rel="icon" href={withBasePath("/favicon.ico")} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
  </head>
  <body class={bodyClass}>
    <Header
      showSearch={headerSearch}
      searchQuery={headerSearchQuery}
      searchPlaceholder={headerSearchPlaceholder}
    />
    <div class:list={["page-shell", !showSidebar && "page-shell--single", shellClass]}>
      <main class="content-column">
        <div class:list={["content-panel", wideContent && "content-panel--wide", panelClass]}>
          <slot />
        </div>
      </main>
      {showSidebar && <Sidebar />}
    </div>
    <Footer />
  </body>
</html>
