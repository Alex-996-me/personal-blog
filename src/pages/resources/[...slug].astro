---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getResourceSlug,
  getResourceUpdatedDate,
  isImageResource,
  isPdfResource,
} from "../../lib/blog";
import { withBasePath } from "../../lib/paths";

export async function getStaticPaths() {
  const resources = await getCollection("resources");
  return resources
    .filter((resource) => resource.data.published !== false)
    .map((resource) => ({
    params: { slug: getResourceSlug(resource) },
    props: { resource },
    }));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
const updated = getResourceUpdatedDate(resource);
const fileUrl = withBasePath(resource.data.file);
const canPreviewPdf = isPdfResource(resource.data.file);
const canPreviewImage = isImageResource(resource.data.file);
const hasBody = resource.body.trim().length > 0;
---

<BaseLayout title={resource.data.title} description={resource.data.description} ogImage={resource.data.cover}>
  <article>
    <a class="post-backlink" href={withBasePath("/resources/")}>
      ← 返回资料
    </a>

    <header class="post-header">
      <h1>{resource.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(resource.data.date)}</span>
        <span>最后更新：{formatDate(updated)}</span>
        <span>资料</span>
      </div>
      {resource.data.tags.length > 0 && (
        <div class="tag-list" aria-label="资料标签">
          {resource.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
      <div class="resource-card__actions resource-card__actions--detail">
        <a href={fileUrl} target="_blank" rel="noopener noreferrer">
          在线阅读
        </a>
        <a href={fileUrl} download>
          下载资料
        </a>
      </div>
    </header>

    {canPreviewPdf && (
      <div class="resource-viewer">
        <iframe src={`${fileUrl}#view=FitH`} title={`${resource.data.title} 在线阅读`} loading="lazy"></iframe>
      </div>
    )}

    {!canPreviewPdf && canPreviewImage && (
      <figure class="post-figure post-figure--wide">
        <img src={fileUrl} alt={resource.data.title} />
      </figure>
    )}

    {!canPreviewPdf && !canPreviewImage && (
      <div class="empty-state">
        这个文件类型目前不适合站内预览，请使用上方的“在线阅读”或“下载资料”打开。
      </div>
    )}

    {hasBody && (
      <div class="prose">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
