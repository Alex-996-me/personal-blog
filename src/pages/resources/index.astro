---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResourceCard from "../../components/ResourceCard.astro";
import { getAllResources } from "../../lib/blog";
import { withBasePath } from "../../lib/paths";

const resources = await getAllResources();
---

<BaseLayout
  title="资料"
  description="可在线阅读和下载的 PDF、讲义、课程资料与参考材料。"
  wideContent={true}
  bodyClass="body--archive"
  shellClass="page-shell--archive"
  panelClass="content-panel--archive"
>
  <section class="page-header page-header--archive">
    <a class="post-backlink" href={withBasePath("/")}>← 返回首页</a>
    <h1>资料</h1>
    <p>这里集中放 PDF、讲义、课程资料和其他方便在线打开或下载的文件。</p>
  </section>

  {resources.length > 0 ? (
    <div class="post-list">
      {resources.map((resource) => (
        <ResourceCard resource={resource} />
      ))}
    </div>
  ) : (
    <div class="empty-state">
      资料库还没有公开文件。以后你只需要把文件放进仓库，再补一份资料说明，它就会显示在这里。
    </div>
  )}
</BaseLayout>
