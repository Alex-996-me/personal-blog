---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSearchEntries } from "../lib/blog";
import { withBasePath } from "../lib/paths";

const searchEntries = await getSearchEntries();
---

<BaseLayout title="搜索" description="搜索文章、每日灵感与资料。">
  <section class="page-header">
    <h1>搜索内容</h1>
    <p>标题、正文、标签、摘要和资料说明都可以直接检索。</p>
  </section>

  <section class="search-page__panel sidebar-section">
    <form class="search-page__form" action={withBasePath("/search/")} method="get">
      <input id="search-input" type="search" name="q" placeholder="输入关键词" />
      <button type="submit">搜索</button>
    </form>
    <p id="search-summary" class="search-page__summary">输入关键词后，会实时筛出相关内容。</p>
    <div id="search-results" class="post-list"></div>
  </section>

  <script define:vars={{ searchEntries }}>
    const entries = searchEntries;
    const input = document.querySelector("#search-input");
    const results = document.querySelector("#search-results");
    const summary = document.querySelector("#search-summary");
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q") ?? "";

    const escapeHtml = (value) =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;");

    const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const normalizeKeywords = (value) =>
      value
        .trim()
        .toLowerCase()
        .split(/\s+/)
        .filter(Boolean);

    const highlightTerms = (text, keywords) => {
      if (!text || keywords.length === 0) {
        return escapeHtml(text);
      }

      const pattern = new RegExp(`(${keywords.map(escapeRegExp).join("|")})`, "gi");
      return escapeHtml(text).replace(pattern, '<mark class="search-hit">$1</mark>');
    };

    const createSnippet = (entry, keywords) => {
      if (keywords.length === 0) {
        return entry.description;
      }

      const source = entry.snippet || entry.description;
      const lowerSource = source.toLowerCase();
      const firstIndex = keywords.reduce((current, keyword) => {
        const index = lowerSource.indexOf(keyword);
        if (index === -1) {
          return current;
        }
        if (current === -1) {
          return index;
        }
        return Math.min(current, index);
      }, -1);

      if (firstIndex === -1) {
        return entry.description;
      }

      const start = Math.max(0, firstIndex - 30);
      const end = Math.min(source.length, firstIndex + 90);
      const prefix = start > 0 ? "..." : "";
      const suffix = end < source.length ? "..." : "";
      return `${prefix}${source.slice(start, end).trim()}${suffix}`;
    };

    const renderResults = (query) => {
      const keywords = normalizeKeywords(query);
      input.value = query;

      if (keywords.length === 0) {
        summary.textContent = "输入关键词后，会实时筛出相关内容。";
        results.innerHTML = "";
        return;
      }

      const filtered = entries.filter((entry) => {
        return keywords.every((keyword) => entry.text.includes(keyword));
      });

      summary.textContent = `找到 ${filtered.length} 条和“${query}”相关的内容。`;

      if (filtered.length === 0) {
        results.innerHTML = '<div class="empty-state">没有找到匹配结果，可以换个关键词试试。</div>';
        return;
      }

      results.innerHTML = filtered
        .map(
          (entry) => `
            <article class="post-card">
              <div class="post-card__content">
                <div class="post-card__meta">
                  <span>发布：${escapeHtml(entry.date)}</span>
                  <span>更新：${escapeHtml(entry.updated)}</span>
                  <span>${escapeHtml(entry.kind)}</span>
                  <span>${escapeHtml(entry.section)}</span>
                </div>
                <h2 class="post-card__title">
                  <a href="${entry.url}">${highlightTerms(entry.title, keywords)}</a>
                </h2>
                <p class="post-card__description">${highlightTerms(createSnippet(entry, keywords), keywords)}</p>
              </div>
              ${
                entry.cover
                  ? `
                    <a class="post-card__media" href="${entry.url}" aria-hidden="true" tabindex="-1">
                      <img class="post-card__cover" src="${entry.cover}" alt="" />
                    </a>
                  `
                  : ""
              }
            </article>
          `,
        )
        .join("");
    };

    input.addEventListener("input", (event) => {
      renderResults(event.currentTarget.value);
    });

    renderResults(initialQuery);
  </script>
</BaseLayout>
