---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getWeeklyMottoForDate, weeklyMottos } from "../data/weekly-mottos";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getInspirationHref,
  getPostHref,
  getUpdatedDate,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations] = await Promise.all([getAllPosts(), getAllInspirations()]);

const latestPosts = posts.slice(0, 3);
const latestInspiration = inspirations[0];
const currentQuery = Astro.url.searchParams.get("q") ?? "";
const todayMotto = getWeeklyMottoForDate(new Date());
const latestInspirationRender = latestInspiration ? await render(latestInspiration) : null;
const LatestInspirationContent = latestInspirationRender?.Content ?? null;

function splitMottoWords(value: string) {
  return value.split(/\s+/).filter(Boolean);
}
---

<BaseLayout
  showSidebar={false}
  wideContent={true}
  bodyClass="body--home"
  shellClass="page-shell--home"
  panelClass="content-panel--home"
>
  <section class="home-hero">
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__ghost home-hero__ghost--en" data-motto-ghost-en>{todayMotto.en}</span>
      <span class="home-hero__ghost home-hero__ghost--zh" data-motto-ghost-zh>{todayMotto.zh}</span>
    </div>

    <div class="home-hero__grid">
      <div class="home-motto-card">
        <div class="home-motto-card__main">
          <p class="home-motto-card__eyebrow" data-motto-day>
            {todayMotto.dayEn.toUpperCase()} · {todayMotto.dayZh}
          </p>
          <h1 class="home-motto-card__headline">
            <span class="home-motto-card__en" data-motto-en>
              {splitMottoWords(todayMotto.en).map((word) => <span>{word}</span>)}
            </span>
            <span class="home-motto-card__zh" data-motto-zh>{todayMotto.zh}</span>
          </h1>
        </div>
      </div>

      <aside class="home-search-card" aria-label="站内搜索">
        <form class="search-form search-form--hero" action={withBasePath("/search/")} method="get">
          <input
            type="search"
            name="q"
            value={currentQuery}
            placeholder="搜索文章标题、正文、标签、灵感"
          />
          <button type="submit">搜索</button>
        </form>
      </aside>
    </div>
  </section>

  <section class="home-journal-block" aria-label="最新文章">
    <div class="home-block-heading">
      <div class="home-block-heading__left">
        <span class="home-block-heading__index">§ 01 · ARTICLES</span>
        <h2>The journal <em>— recently revised</em></h2>
      </div>
    </div>

    <div class="home-article-grid">
      {latestPosts.map((post) => (
        <a class="home-article-card" href={withBasePath(getPostHref(post))}>
          <div class="home-article-card__media">
            {post.data.cover ? (
              <img
                class="home-article-card__cover"
                src={withBasePath(post.data.cover)}
                alt={post.data.title}
                loading="lazy"
              />
            ) : (
              <div class="home-article-card__cover home-article-card__cover--fallback">
                <span>{post.data.category}</span>
                <strong>{post.data.title}</strong>
              </div>
            )}
          </div>
          <div class="home-article-card__body">
            <div class="home-article-card__meta">
              <span>更新于 {formatDate(getUpdatedDate(post))}</span>
              <span>{post.data.category}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p class="home-article-card__summary">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {latestInspiration && LatestInspirationContent && (
    <section class="home-inspiration-block" data-home-reveal aria-label="最新灵感">
      <div class="home-block-heading home-block-heading--inspiration">
        <div class="home-block-heading__left">
          <span class="home-block-heading__index">§ 02 · INSPIRATION</span>
          <h2>Latest spark <em>— scroll to unfold</em></h2>
        </div>
        <a class="home-block-heading__all" href={withBasePath("/daily/")}>ALL →</a>
      </div>

      <div class="home-inspiration-shell">
        <div class="home-inspiration-shell__bar">
          <span class="home-inspiration-shell__theme">{latestInspiration.data.theme}</span>
          <span class="home-inspiration-shell__title">{latestInspiration.data.title}</span>
        </div>

        <div class="home-inspiration-shell__panel">
          <div class="home-inspiration-shell__content">
            <LatestInspirationContent />
          </div>
        </div>
      </div>
    </section>
  )}

  <script is:inline define:vars={{ weeklyMottos }}>
    const getMondayFirstIndex = (day) => (day + 6) % 7;
    const today = weeklyMottos[getMondayFirstIndex(new Date().getDay())];
    const dayNode = document.querySelector("[data-motto-day]");
    const enNode = document.querySelector("[data-motto-en]");
    const zhNode = document.querySelector("[data-motto-zh]");
    const ghostEnNode = document.querySelector("[data-motto-ghost-en]");
    const ghostZhNode = document.querySelector("[data-motto-ghost-zh]");

    if (today && dayNode && enNode && zhNode && ghostEnNode && ghostZhNode) {
      dayNode.textContent = `${today.dayEn.toUpperCase()} · ${today.dayZh}`;
      enNode.replaceChildren(
        ...today.en.split(/\s+/).filter(Boolean).map((word) => {
          const span = document.createElement("span");
          span.textContent = word;
          return span;
        })
      );
      zhNode.textContent = today.zh;
      ghostEnNode.textContent = today.en;
      ghostZhNode.textContent = today.zh;
    }

    const islandBlock = document.querySelector("[data-home-reveal]");
    if (islandBlock) {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let ticking = false;

      const updateIslandProgress = () => {
        const rect = islandBlock.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const compact = window.innerWidth <= 720;
        const start = viewportHeight * 0.92;
        const end = viewportHeight * 0.26;
        const range = Math.max(start - end, 1);
        let progress = (start - rect.top) / range;

        if (rect.top <= end && rect.bottom >= viewportHeight * 0.34) {
          progress = 1;
        }

        progress = Math.max(0, Math.min(1, progress));

        if (prefersReducedMotion) {
          progress = progress > 0.08 ? 1 : 0;
        }

        const mix = (from, to) => from + (to - from) * progress;
        const setVar = (name, value) => islandBlock.style.setProperty(name, value);
        const barClosedWidth = compact ? 84 : 74;
        const barOpenWidth = 100;
        const barClosedHeight = compact ? 54 : 56;
        const barOpenHeight = compact ? 62 : 68;
        const barClosedPad = compact ? 1 : 1;
        const barOpenPad = compact ? 1.12 : 1.28;
        const panelOpenHeight = compact ? 620 : 540;
        const proseOpenFont = compact ? 1.12 : 1.16;

        islandBlock.style.setProperty("--island-progress", progress.toFixed(4));
        setVar("--island-bar-width", `${mix(barClosedWidth, barOpenWidth).toFixed(2)}%`);
        setVar("--island-bar-min-height", `${mix(barClosedHeight, barOpenHeight).toFixed(2)}px`);
        setVar("--island-bar-padding-x", `${mix(barClosedPad, barOpenPad).toFixed(3)}rem`);
        setVar("--island-bar-radius", `${mix(999, 27).toFixed(2)}px`);
        setVar("--island-bar-bg-alpha", mix(0.9, 0.96).toFixed(3));
        setVar("--island-bar-shadow-y", `${mix(10, 20).toFixed(2)}px`);
        setVar("--island-bar-shadow-blur", `${mix(28, 44).toFixed(2)}px`);
        setVar("--island-bar-shadow-alpha", mix(0.14, 0.3).toFixed(3));
        setVar("--island-bar-inset-alpha", mix(0.03, 0.08).toFixed(3));
        setVar("--island-bar-shift", `${mix(20, 0).toFixed(2)}px`);
        setVar("--island-bar-scale", mix(0.92, 1).toFixed(4));
        setVar("--island-sheen-alpha", mix(0.05, 0.09).toFixed(3));
        setVar("--island-theme-font-size", `${mix(compact ? 0.72 : 0.76, compact ? 0.84 : 0.88).toFixed(3)}rem`);
        setVar("--island-theme-letter-spacing", `${mix(0.12, 0.14).toFixed(3)}em`);
        setVar("--island-theme-opacity", mix(0.68, 1).toFixed(3));
        setVar("--island-theme-shift", `${mix(5, 0).toFixed(2)}px`);
        setVar("--island-title-font-size", `${mix(compact ? 0.95 : 0.94, compact ? 1.05 : 1.12).toFixed(3)}rem`);
        setVar("--island-title-letter-spacing", `${mix(0, 0.015).toFixed(3)}em`);
        setVar("--island-title-opacity", mix(0.76, 1).toFixed(3));
        setVar("--island-title-shift", `${mix(4, 0).toFixed(2)}px`);
        setVar("--island-panel-margin-top", `${mix(0.45, 0.95).toFixed(3)}rem`);
        setVar("--island-panel-max-height", `${mix(compact ? 34 : 36, panelOpenHeight).toFixed(2)}px`);
        setVar("--island-panel-opacity", Math.max(0, Math.min(1, progress * 1.25 - 0.05)).toFixed(3));
        setVar("--island-panel-blur", `${mix(10, 0).toFixed(2)}px`);
        setVar("--island-panel-clip", `${mix(100, 0).toFixed(2)}%`);
        setVar("--island-panel-rotate", `${mix(-12, 0).toFixed(2)}deg`);
        setVar("--island-panel-shift", `${mix(34, 0).toFixed(2)}px`);
        setVar("--island-panel-scale", mix(0.96, 1).toFixed(4));
        setVar("--island-content-opacity", Math.max(0, Math.min(1, progress * 1.22 - 0.08)).toFixed(3));
        setVar("--island-content-shift", `${mix(16, 0).toFixed(2)}px`);
        setVar("--island-content-scale", mix(0.985, 1).toFixed(4));
        setVar("--island-prose-font-size", `${mix(1, proseOpenFont).toFixed(3)}rem`);
        islandBlock.classList.toggle("is-revealed", progress > 0.02);
        islandBlock.classList.toggle("is-expanded", progress > 0.74);
      };

      const requestProgressUpdate = () => {
        if (ticking) {
          return;
        }

        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          updateIslandProgress();
        });
      };

      updateIslandProgress();
      window.addEventListener("scroll", requestProgressUpdate, { passive: true });
      window.addEventListener("resize", requestProgressUpdate);
      window.addEventListener("orientationchange", requestProgressUpdate);
    }
  </script>
</BaseLayout>
