---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getInspirationHref,
  getPostHref,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations] = await Promise.all([getAllPosts(), getAllInspirations()]);

const latestPost = posts[0];
const previousPost = posts[1];
const latestInspiration = inspirations[0];
const previousInspiration = inspirations[1];
const currentQuery = Astro.url.searchParams.get("q") ?? "";
---

<BaseLayout
  showSidebar={false}
  wideContent={true}
  bodyClass="body--home"
  shellClass="page-shell--home"
  panelClass="content-panel--home"
>
  <section class="home-search-panel" aria-label="首页搜索">
    <form class="search-form search-form--home" action={withBasePath("/search/")} method="get">
      <input
        type="search"
        name="q"
        value={currentQuery}
        placeholder="搜索文章标题、正文、标签、灵感"
      />
      <button type="submit">搜索</button>
    </form>
  </section>

  <section class="home-showcase" aria-label="首页内容">
    {latestPost ? (
      <article class="home-section">
        <div class="home-section__header">
          <p class="home-section__label">文章</p>
          <a class="home-section__more" href={withBasePath(getPostHref(latestPost))}>阅读全文</a>
        </div>

        <a class="home-spotlight home-spotlight--post" href={withBasePath(getPostHref(latestPost))}>
          <div class="home-spotlight__topline">
            <span>{formatDate(latestPost.data.date)}</span>
            <span>{latestPost.data.category}</span>
          </div>
          <h2>{latestPost.data.title}</h2>
          <p class="home-spotlight__description">{latestPost.data.description}</p>

          {previousPost && (
            <div class="home-spotlight__previous">
              <span class="home-spotlight__previous-label">上一篇</span>
              <span class="home-spotlight__previous-title">{previousPost.data.title}</span>
            </div>
          )}
        </a>
      </article>
    ) : null}

    {latestInspiration ? (
      <article class="home-section">
        <div class="home-section__header">
          <p class="home-section__label">灵感</p>
          <a class="home-section__more" href={withBasePath("/daily/")}>进入灵感流</a>
        </div>

        <a
          class="home-spotlight home-spotlight--inspiration"
          href={withBasePath(getInspirationHref(latestInspiration))}
        >
          <div class="home-spotlight__topline">
            <span>{formatDate(latestInspiration.data.date)}</span>
            <span>{latestInspiration.data.theme}</span>
          </div>
          <h2>{latestInspiration.data.title}</h2>
          <p class="home-spotlight__description">{latestInspiration.data.description}</p>

          {previousInspiration && (
            <div class="home-spotlight__previous">
              <span class="home-spotlight__previous-label">上一条</span>
              <span class="home-spotlight__previous-title">{previousInspiration.data.title}</span>
            </div>
          )}
        </a>
      </article>
    ) : null}
  </section>
</BaseLayout>
