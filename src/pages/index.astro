---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getWeeklyMottoForDate, weeklyMottos } from "../data/weekly-mottos";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getPostHref,
  getUpdatedDate,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations] = await Promise.all([getAllPosts(), getAllInspirations()]);

const latestPosts = posts.slice(0, 3);
const latestInspiration = inspirations[0];
const currentQuery = Astro.url.searchParams.get("q") ?? "";
const todayMotto = getWeeklyMottoForDate(new Date());
const latestInspirationRender = latestInspiration ? await render(latestInspiration) : null;
const LatestInspirationContent = latestInspirationRender?.Content ?? null;

function splitMottoWords(value: string) {
  return value.split(/\s+/).filter(Boolean);
}
---

<BaseLayout
  showSidebar={false}
  wideContent={true}
  bodyClass="body--home"
  shellClass="page-shell--home"
  panelClass="content-panel--home"
  headerSearch={true}
  headerSearchQuery={currentQuery}
  headerSearchPlaceholder="搜索文章、正文、标签、灵感"
>
  <section class="home-hero">
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__ghost home-hero__ghost--en" data-motto-ghost-en>{todayMotto.en}</span>
      <span class="home-hero__ghost home-hero__ghost--zh" data-motto-ghost-zh>{todayMotto.zh}</span>
    </div>

    <div class="home-hero__grid">
      <div class="home-motto-card">
        <p class="home-motto-card__eyebrow" data-motto-day>
          {todayMotto.dayEn.toUpperCase()} · {todayMotto.dayZh}
        </p>

        <h1 class="home-motto-card__headline">
          <span class="home-motto-card__en" data-motto-en>
            {splitMottoWords(todayMotto.en).map((word) => <span>{word}</span>)}
          </span>
          <span class="home-motto-card__zh" data-motto-zh>{todayMotto.zh}</span>
        </h1>
      </div>
    </div>
  </section>

  <section class="home-stage home-stage--journal" data-home-stage>
    <div class="home-stage__surface home-stage__surface--journal">
      <div class="home-block-heading home-block-heading--journal">
        <div class="home-block-heading__left">
          <span class="home-block-heading__index">01 · JOURNAL</span>
          <h2>最新文章</h2>
        </div>
      </div>

      <div class="home-article-grid">
        {latestPosts.map((post) => (
          <a class="home-article-card" href={withBasePath(getPostHref(post))}>
            <div class="home-article-card__media">
              {post.data.cover ? (
                <img
                  class="home-article-card__cover"
                  src={withBasePath(post.data.cover)}
                  alt={post.data.title}
                  loading="lazy"
                />
              ) : (
                <div class="home-article-card__cover home-article-card__cover--fallback">
                  <span>{post.data.category}</span>
                  <strong>{post.data.title}</strong>
                </div>
              )}
            </div>

            <div class="home-article-card__body">
              <div class="home-article-card__meta">
                <span>{formatDate(getUpdatedDate(post))}</span>
                <span>{post.data.category}</span>
              </div>
              <h3>{post.data.title}</h3>
              <p class="home-article-card__summary">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {latestInspiration && LatestInspirationContent && (
    <section class="home-stage home-stage--spark" data-home-stage>
      <div class="home-stage__surface home-stage__surface--spark">
        <div class="home-block-heading home-block-heading--spark">
          <div class="home-block-heading__left">
            <span class="home-block-heading__index">02 · SPARK</span>
            <h2>最新灵感</h2>
          </div>
          <a class="home-block-heading__all" href={withBasePath("/daily/")}>ALL</a>
        </div>

        <div class="home-inspiration-shell">
          <div class="home-inspiration-shell__bar">
            <span class="home-inspiration-shell__theme">{latestInspiration.data.theme}</span>
            <span class="home-inspiration-shell__title">{latestInspiration.data.title}</span>
          </div>

          <div class="home-inspiration-shell__panel">
            <div class="home-inspiration-shell__content">
              <LatestInspirationContent />
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <script is:inline define:vars={{ weeklyMottos }}>
    const getMondayFirstIndex = (day) => (day + 6) % 7;
    const today = weeklyMottos[getMondayFirstIndex(new Date().getDay())];

    const dayNode = document.querySelector("[data-motto-day]");
    const enNode = document.querySelector("[data-motto-en]");
    const zhNode = document.querySelector("[data-motto-zh]");
    const ghostEnNode = document.querySelector("[data-motto-ghost-en]");
    const ghostZhNode = document.querySelector("[data-motto-ghost-zh]");

    if (today && dayNode && enNode && zhNode && ghostEnNode && ghostZhNode) {
      dayNode.textContent = `${today.dayEn.toUpperCase()} · ${today.dayZh}`;
      enNode.replaceChildren(
        ...today.en.split(/\s+/).filter(Boolean).map((word) => {
          const span = document.createElement("span");
          span.textContent = word;
          return span;
        }),
      );
      zhNode.textContent = today.zh;
      ghostEnNode.textContent = today.en;
      ghostZhNode.textContent = today.zh;
    }

    const stages = Array.from(document.querySelectorAll("[data-home-stage]"));
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reducedMotion && stages.length > 0) {
      const stageObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const target = entry.target;
            const active = entry.isIntersecting && entry.intersectionRatio > 0.14;
            target.classList.toggle("is-active", active);
          });
        },
        {
          threshold: [0.14, 0.22, 0.36],
          rootMargin: "0px 0px -8% 0px",
        },
      );

      stages.forEach((stage) => stageObserver.observe(stage));
    } else {
      stages.forEach((stage) => stage.classList.add("is-active"));
    }
  </script>
</BaseLayout>
