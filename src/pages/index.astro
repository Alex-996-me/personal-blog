---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getWeeklyMottoForDate, weeklyMottos } from "../data/weekly-mottos";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getPostHref,
  getUpdatedDate,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations] = await Promise.all([getAllPosts(), getAllInspirations()]);

const latestPosts = posts.slice(0, 3);
const latestInspiration = inspirations[0];
const currentQuery = Astro.url.searchParams.get("q") ?? "";
const todayMotto = getWeeklyMottoForDate(new Date());
const latestInspirationRender = latestInspiration ? await render(latestInspiration) : null;
const LatestInspirationContent = latestInspirationRender?.Content ?? null;

function splitMottoWords(value: string) {
  return value.split(/\s+/).filter(Boolean);
}
---

<BaseLayout
  showSidebar={false}
  wideContent={true}
  bodyClass="body--home"
  shellClass="page-shell--home"
  panelClass="content-panel--home"
>
  <section class="home-hero">
    <div class="home-hero__backdrop" aria-hidden="true">
      <span class="home-hero__ghost home-hero__ghost--en" data-motto-ghost-en>{todayMotto.en}</span>
      <span class="home-hero__ghost home-hero__ghost--zh" data-motto-ghost-zh>{todayMotto.zh}</span>
    </div>

    <div class="home-hero__grid">
      <div class="home-motto-card">
        <div class="home-motto-card__main">
          <p class="home-motto-card__eyebrow" data-motto-day>
            {todayMotto.dayEn.toUpperCase()} · {todayMotto.dayZh}
          </p>
          <h1 class="home-motto-card__headline">
            <span class="home-motto-card__en" data-motto-en>
              {splitMottoWords(todayMotto.en).map((word) => <span>{word}</span>)}
            </span>
            <span class="home-motto-card__zh" data-motto-zh>{todayMotto.zh}</span>
          </h1>
        </div>
      </div>

      <aside class="home-search-card" aria-label="站内搜索">
        <form class="search-form search-form--hero" action={withBasePath("/search/")} method="get">
          <input
            type="search"
            name="q"
            value={currentQuery}
            placeholder="搜索文章、正文、标签、灵感"
          />
          <button type="submit">搜索</button>
        </form>
      </aside>
    </div>
  </section>

  <section class="home-scroll-stage home-scroll-stage--journal" data-scroll-stage="journal">
    <div class="home-scroll-stage__sticky">
      <section class="home-journal-block" data-home-journal aria-label="Latest journal articles">
        <div class="home-block-heading home-block-heading--journal">
          <div class="home-block-heading__left">
            <span class="home-block-heading__index">§ 01 · JOURNAL</span>
            <h2>The journal <em>three recently revised entries</em></h2>
          </div>
        </div>

        <div class="home-article-grid">
          {latestPosts.map((post, index) => (
            <a
              class="home-article-card"
              data-journal-card
              style={`--journal-card-index:${index};`}
              href={withBasePath(getPostHref(post))}
            >
              <div class="home-article-card__media">
                {post.data.cover ? (
                  <img
                    class="home-article-card__cover"
                    src={withBasePath(post.data.cover)}
                    alt={post.data.title}
                    loading="lazy"
                  />
                ) : (
                  <div class="home-article-card__cover home-article-card__cover--fallback">
                    <span>{post.data.category}</span>
                    <strong>{post.data.title}</strong>
                  </div>
                )}
              </div>
              <div class="home-article-card__body">
                <div class="home-article-card__meta">
                  <span>Updated {formatDate(getUpdatedDate(post))}</span>
                  <span>{post.data.category}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p class="home-article-card__summary">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>

  {latestInspiration && LatestInspirationContent && (
    <section class="home-scroll-stage home-scroll-stage--spark" data-scroll-stage="spark">
      <div class="home-scroll-stage__sticky home-scroll-stage__sticky--spark">
        <section class="home-inspiration-block" data-home-reveal aria-label="Latest inspiration">
          <div class="home-block-heading home-block-heading--inspiration">
            <div class="home-block-heading__left">
              <span class="home-block-heading__index">§ 02 · SPARK</span>
              <h2>Latest spark <em>drag down to unfold</em></h2>
            </div>
            <a class="home-block-heading__all" href={withBasePath("/daily/")}>ALL →</a>
          </div>

          <div class="home-inspiration-shell">
            <div class="home-inspiration-shell__bar">
              <span class="home-inspiration-shell__theme">{latestInspiration.data.theme}</span>
              <span class="home-inspiration-shell__title">{latestInspiration.data.title}</span>
            </div>

            <div class="home-inspiration-shell__panel">
              <div class="home-inspiration-shell__content">
                <LatestInspirationContent />
              </div>
            </div>
          </div>
        </section>
      </div>
    </section>
  )}

  <script is:inline define:vars={{ weeklyMottos }}>
    const getMondayFirstIndex = (day) => (day + 6) % 7;
    const today = weeklyMottos[getMondayFirstIndex(new Date().getDay())];
    const dayNode = document.querySelector("[data-motto-day]");
    const enNode = document.querySelector("[data-motto-en]");
    const zhNode = document.querySelector("[data-motto-zh]");
    const ghostEnNode = document.querySelector("[data-motto-ghost-en]");
    const ghostZhNode = document.querySelector("[data-motto-ghost-zh]");

    if (today && dayNode && enNode && zhNode && ghostEnNode && ghostZhNode) {
      dayNode.textContent = `${today.dayEn.toUpperCase()} · ${today.dayZh}`;
      enNode.replaceChildren(
        ...today.en.split(/\s+/).filter(Boolean).map((word) => {
          const span = document.createElement("span");
          span.textContent = word;
          return span;
        })
      );
      zhNode.textContent = today.zh;
      ghostEnNode.textContent = today.en;
      ghostZhNode.textContent = today.zh;
    }

    try {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const clamp = (value, min = 0, max = 1) => Math.max(min, Math.min(max, value));
      const mix = (from, to, progress) => from + (to - from) * progress;
      const easeOutCubic = (value) => 1 - Math.pow(1 - clamp(value), 3);
      const easeInOutCubic = (value) => {
        const progress = clamp(value);
        return progress < 0.5
          ? 4 * progress * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 3) / 2;
      };

      const stageControllers = [];
      let frameId = 0;

      const registerStageController = (stage, { onUpdate }) => {
        if (!stage || typeof onUpdate !== "function") {
          return;
        }

        const state = { current: 0, target: 0 };

        stageControllers.push(() => {
          const rect = stage.getBoundingClientRect();
          const viewportHeight = window.innerHeight;
          const travel = Math.max(rect.height - viewportHeight, 1);
          let target = clamp(-rect.top / travel);

          if (prefersReducedMotion) {
            target = target > 0.08 ? 1 : 0;
          }

          state.target = target;
          const delta = state.target - state.current;
          const settled = Math.abs(delta) < 0.0012;
          state.current = settled ? state.target : state.current + delta * 0.12;

          onUpdate(state.current, {
            rect,
            viewportHeight,
            compact: window.innerWidth <= 720,
          });

          return !settled;
        });
      };

      const renderControllers = () => {
        let needsNextFrame = false;

        stageControllers.forEach((update) => {
          if (update()) {
            needsNextFrame = true;
          }
        });

        if (needsNextFrame) {
          frameId = requestAnimationFrame(renderControllers);
        } else {
          frameId = 0;
        }
      };

      const requestProgressUpdate = () => {
        if (frameId) {
          return;
        }

        frameId = requestAnimationFrame(renderControllers);
      };

      const journalStage = document.querySelector('[data-scroll-stage="journal"]');
      const journalBlock = document.querySelector("[data-home-journal]");
      const journalHeading = journalBlock?.querySelector(".home-block-heading--journal");
      const journalGrid = journalBlock?.querySelector(".home-article-grid");
      const journalCards = journalBlock ? Array.from(journalBlock.querySelectorAll("[data-journal-card]")) : [];

      registerStageController(journalStage, {
        onUpdate: (progress, { compact }) => {
          if (!journalBlock) {
            return;
          }

          const shellProgress = easeInOutCubic(clamp((progress - 0.04) / 0.96));
          const headingProgress = easeOutCubic(clamp((progress - 0.08) / 0.9));
          const cardsProgress = easeOutCubic(clamp((progress - 0.34) / 0.56));

          journalBlock.style.opacity = mix(0.22, 1, shellProgress).toFixed(3);
          journalBlock.style.transform =
            `translateY(${mix(118, 0, shellProgress).toFixed(2)}px) ` +
            `scale(${mix(0.94, 1, shellProgress).toFixed(4)})`;
          journalBlock.style.borderRadius = `${mix(34, 28, shellProgress).toFixed(2)}px`;
          journalBlock.style.background =
            `linear-gradient(180deg, rgba(255,255,255,${mix(0.012, 0.04, shellProgress).toFixed(3)}), transparent 24%), ` +
            `rgba(11,14,18,${mix(0.68, 0.92, shellProgress).toFixed(3)})`;
          journalBlock.style.boxShadow =
            `0 ${mix(24, 48, shellProgress).toFixed(2)}px ${mix(56, 96, shellProgress).toFixed(2)}px rgba(0,0,0,${mix(0.08, 0.24, shellProgress).toFixed(3)}), ` +
            `inset 0 1px 0 rgba(255,255,255,${mix(0.03, 0.08, shellProgress).toFixed(3)})`;
          journalBlock.style.backdropFilter =
            `blur(${mix(8, 22, shellProgress).toFixed(2)}px) saturate(${mix(112, 146, shellProgress).toFixed(1)}%)`;

          if (journalHeading) {
            journalHeading.style.width = `${mix(compact ? 92 : 44, 100, headingProgress).toFixed(2)}%`;
            journalHeading.style.borderRadius = `${mix(999, 28, headingProgress).toFixed(2)}px`;
            journalHeading.style.opacity = mix(0.42, 1, headingProgress).toFixed(3);
            journalHeading.style.filter = `blur(${mix(12, 0, headingProgress).toFixed(2)}px)`;
            journalHeading.style.transform =
              `translateY(${mix(42, 0, headingProgress).toFixed(2)}px) ` +
              `scale(${mix(0.88, 1, headingProgress).toFixed(4)})`;
          }

          if (journalGrid) {
            journalGrid.style.opacity = mix(0.02, 1, cardsProgress).toFixed(3);
            journalGrid.style.transform = `translateY(${mix(34, 0, cardsProgress).toFixed(2)}px)`;
          }

          journalCards.forEach((card, index) => {
            const localProgress = easeOutCubic(clamp((cardsProgress - index * 0.1) / 0.7));
            const lateralShift = compact ? 0 : index === 0 ? -16 : index === 2 ? 16 : 0;
            const cardMedia = card.querySelector(".home-article-card__media");
            const cardCover = card.querySelector(".home-article-card__cover, .home-article-card__cover--fallback");

            card.style.opacity = mix(0.02, 1, localProgress).toFixed(3);
            card.style.filter = `blur(${mix(18, 0, localProgress).toFixed(2)}px)`;
            card.style.transform =
              `translate3d(${mix(lateralShift, 0, localProgress).toFixed(2)}px, ${mix(92 + index * 10, 0, localProgress).toFixed(2)}px, 0) ` +
              `scale(${mix(0.86, 1, localProgress).toFixed(4)}) ` +
              `perspective(1400px) rotateX(${mix(-18 + index * 2, 0, localProgress).toFixed(2)}deg)`;
            card.style.borderColor = `rgba(255,255,255,${mix(0.02, 0.12, localProgress).toFixed(3)})`;
            card.style.background =
              `linear-gradient(180deg, rgba(255,255,255,${mix(0.03, 0.08, localProgress).toFixed(3)}), rgba(255,255,255,0.015)), ` +
              `rgba(14,18,24,${mix(0.18, 0.56, localProgress).toFixed(3)})`;
            card.style.boxShadow =
              `0 ${mix(16, 34, localProgress).toFixed(2)}px ${mix(34, 78, localProgress).toFixed(2)}px rgba(0,0,0,${mix(0.04, 0.22, localProgress).toFixed(3)}), ` +
              `inset 0 1px 0 rgba(255,255,255,${mix(0.04, 0.08, localProgress).toFixed(3)})`;

            if (cardMedia) {
              cardMedia.style.transform = `scale(${mix(1.08, 1, localProgress).toFixed(4)})`;
              cardMedia.style.filter =
                `blur(${mix(4, 0, localProgress).toFixed(2)}px) ` +
                `brightness(${mix(0.82, 1, localProgress).toFixed(3)})`;
            }

            if (cardCover) {
              cardCover.style.opacity = mix(0.68, 1, localProgress).toFixed(3);
            }
          });
        },
      });

      const sparkStage = document.querySelector('[data-scroll-stage="spark"]');
      const sparkBlock = document.querySelector("[data-home-reveal]");
      const sparkHeading = sparkBlock?.querySelector(".home-block-heading--inspiration");
      const sparkShell = sparkBlock?.querySelector(".home-inspiration-shell");
      const islandBar = sparkBlock?.querySelector(".home-inspiration-shell__bar");
      const islandTheme = sparkBlock?.querySelector(".home-inspiration-shell__theme");
      const islandTitle = sparkBlock?.querySelector(".home-inspiration-shell__title");
      const islandPanel = sparkBlock?.querySelector(".home-inspiration-shell__panel");
      const islandContent = sparkBlock?.querySelector(".home-inspiration-shell__content");
      const islandProseNodes = islandContent
        ? Array.from(islandContent.querySelectorAll(".prose, .prose--inspiration"))
        : [];

      registerStageController(sparkStage, {
        onUpdate: (progress, { compact }) => {
          if (!sparkBlock || !sparkShell) {
            return;
          }

          const shellProgress = easeInOutCubic(clamp((progress - 0.02) / 0.98));
          const barProgress = easeOutCubic(clamp((progress - 0.08) / 0.92));
          const panelProgress = easeOutCubic(clamp((progress - 0.46) / 0.54));
          const shellWidth = sparkShell.clientWidth || sparkBlock.clientWidth || window.innerWidth;
          const barClosedWidth = compact ? Math.max(228, shellWidth * 0.72) : Math.min(420, shellWidth * 0.42);
          const barOpenWidth = shellWidth;

          sparkBlock.style.opacity = mix(0.14, 1, shellProgress).toFixed(3);
          sparkBlock.style.transform =
            `translateY(${mix(128, 0, shellProgress).toFixed(2)}px) ` +
            `scale(${mix(0.93, 1, shellProgress).toFixed(4)})`;
          sparkBlock.style.borderRadius = `${mix(34, 28, shellProgress).toFixed(2)}px`;
          sparkBlock.style.background =
            `linear-gradient(180deg, rgba(255,255,255,${mix(0.008, 0.03, shellProgress).toFixed(3)}), transparent 22%), ` +
            `rgba(10,13,17,${mix(0.72, 0.94, shellProgress).toFixed(3)})`;
          sparkBlock.style.boxShadow =
            `0 ${mix(18, 44, shellProgress).toFixed(2)}px ${mix(40, 88, shellProgress).toFixed(2)}px rgba(0,0,0,${mix(0.06, 0.24, shellProgress).toFixed(3)}), ` +
            `inset 0 1px 0 rgba(255,255,255,${mix(0.03, 0.07, shellProgress).toFixed(3)})`;

          if (sparkHeading) {
            sparkHeading.style.opacity = mix(0.28, 1, shellProgress).toFixed(3);
            sparkHeading.style.transform =
              `translateY(${mix(38, 0, shellProgress).toFixed(2)}px) ` +
              `scale(${mix(0.92, 1, shellProgress).toFixed(4)})`;
            sparkHeading.style.filter = `blur(${mix(10, 0, shellProgress).toFixed(2)}px)`;
          }

          if (islandBar) {
            islandBar.style.width = `${mix(barClosedWidth, barOpenWidth, barProgress).toFixed(2)}px`;
            islandBar.style.minHeight = `${mix(compact ? 62 : 66, compact ? 74 : 82, barProgress).toFixed(2)}px`;
            islandBar.style.paddingLeft = `${mix(compact ? 1 : 1.1, compact ? 1.28 : 1.6, barProgress).toFixed(3)}rem`;
            islandBar.style.paddingRight = `${mix(compact ? 1 : 1.1, compact ? 1.28 : 1.6, barProgress).toFixed(3)}rem`;
            islandBar.style.borderRadius = `${mix(999, 30, barProgress).toFixed(2)}px`;
            islandBar.style.background = `rgba(12,16,22,${mix(0.84, 0.96, barProgress).toFixed(3)})`;
            islandBar.style.boxShadow =
              `0 ${mix(12, 28, barProgress).toFixed(2)}px ${mix(26, 62, barProgress).toFixed(2)}px rgba(0,0,0,${mix(0.1, 0.32, barProgress).toFixed(3)}), ` +
              `inset 0 1px 0 rgba(255,255,255,${mix(0.03, 0.08, barProgress).toFixed(3)})`;
            islandBar.style.transform =
              `translateY(${mix(34, 0, barProgress).toFixed(2)}px) ` +
              `scale(${mix(0.93, 1, barProgress).toFixed(4)})`;
          }

          if (islandTheme) {
            islandTheme.style.fontSize = `${mix(compact ? 0.76 : 0.8, compact ? 0.88 : 0.92, barProgress).toFixed(3)}rem`;
            islandTheme.style.letterSpacing = `${mix(0.1, 0.16, barProgress).toFixed(3)}em`;
            islandTheme.style.opacity = mix(0.62, 1, barProgress).toFixed(3);
            islandTheme.style.transform = `translateY(${mix(8, 0, barProgress).toFixed(2)}px)`;
          }

          if (islandTitle) {
            islandTitle.style.fontSize = `${mix(compact ? 1 : 1.04, compact ? 1.14 : 1.2, barProgress).toFixed(3)}rem`;
            islandTitle.style.letterSpacing = `${mix(0, 0.016, barProgress).toFixed(3)}em`;
            islandTitle.style.opacity = mix(0.62, 1, barProgress).toFixed(3);
            islandTitle.style.transform = `translateY(${mix(10, 0, barProgress).toFixed(2)}px)`;
          }

          if (islandPanel) {
            islandPanel.style.marginTop = `${mix(0.2, 1, panelProgress).toFixed(3)}rem`;
            islandPanel.style.maxHeight = `${mix(0, compact ? 920 : 760, panelProgress).toFixed(2)}px`;
            islandPanel.style.opacity = mix(0, 1, panelProgress).toFixed(3);
            islandPanel.style.filter = `blur(${mix(18, 0, panelProgress).toFixed(2)}px)`;
            islandPanel.style.clipPath = `inset(0 0 ${mix(100, 0, panelProgress).toFixed(2)}% 0 round 28px)`;
            islandPanel.style.transform =
              `perspective(1600px) rotateX(${mix(-22, 0, panelProgress).toFixed(2)}deg) ` +
              `translateY(${mix(88, 0, panelProgress).toFixed(2)}px) ` +
              `scale(${mix(0.9, 1, panelProgress).toFixed(4)})`;
            islandPanel.style.boxShadow =
              `0 ${mix(16, 32, panelProgress).toFixed(2)}px ${mix(36, 72, panelProgress).toFixed(2)}px rgba(0,0,0,${mix(0.08, 0.24, panelProgress).toFixed(3)})`;
          }

          if (islandContent) {
            islandContent.style.opacity = mix(0, 1, panelProgress).toFixed(3);
            islandContent.style.transform =
              `translateY(${mix(28, 0, panelProgress).toFixed(2)}px) ` +
              `scale(${mix(0.97, 1, panelProgress).toFixed(4)})`;
          }

          islandProseNodes.forEach((node) => {
            node.style.fontSize = `${mix(1.02, compact ? 1.14 : 1.18, panelProgress).toFixed(3)}rem`;
          });
        },
      });

      requestProgressUpdate();
      window.addEventListener("scroll", requestProgressUpdate, { passive: true });
      window.addEventListener("wheel", requestProgressUpdate, { passive: true });
      window.addEventListener("touchmove", requestProgressUpdate, { passive: true });
      window.addEventListener("resize", requestProgressUpdate);
      window.addEventListener("orientationchange", requestProgressUpdate);
    } catch (error) {
      window.__homeProgressError = error instanceof Error ? error.message : String(error);
      console.error("[home-progress]", error);
    }
  </script>
</BaseLayout>
