---
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import { getWeeklyMottoForDate, weeklyMottos } from "../data/weekly-mottos";
import { siteConfig, topicMatrix } from "../data/site";
import {
  formatDate,
  getAllInspirations,
  getAllPosts,
  getAllResources,
  getCategoryCounts,
  getPostHref,
  getUpdatedDate,
} from "../lib/blog";
import { withBasePath } from "../lib/paths";

const [posts, inspirations, resources] = await Promise.all([
  getAllPosts(),
  getAllInspirations(),
  getAllResources(),
]);

const latestPosts = posts.slice(0, 3);
const latestInspiration = inspirations[0];
const todayMotto = getWeeklyMottoForDate(new Date());
const latestInspirationRender = latestInspiration ? await render(latestInspiration) : null;
const LatestInspirationContent = latestInspirationRender?.Content ?? null;
const categoryCounts = getCategoryCounts(posts, { includeHidden: false });
const topicTiles = topicMatrix.map((topic) => ({
  ...topic,
  count:
    topic.slug === "resources"
      ? resources.length
      : (categoryCounts.find((category) => category.slug === topic.slug)?.count ?? 0),
}));

function splitMottoWords(value: string) {
  return value.split(/\s+/).filter(Boolean);
}

function splitChineseMotto(value: string) {
  const normalized = value.trim();
  const parts = normalized
    .split(/[，、；]/)
    .map((part) => part.trim())
    .filter(Boolean);

  if (parts.length > 1) {
    return parts;
  }

  if (normalized.length <= 4) {
    const midpoint = Math.ceil(normalized.length / 2);
    return [normalized.slice(0, midpoint), normalized.slice(midpoint)].filter(Boolean);
  }

  if (normalized.length <= 6) {
    return [normalized.slice(0, 3), normalized.slice(3)].filter(Boolean);
  }

  return [normalized];
}
---

<BaseLayout
  showSidebar={false}
  wideContent={true}
  bodyClass="body--hub-home"
  shellClass="page-shell--hub-home"
  panelClass="content-panel--hub-home"
>
  <div class="lab-home">
    <section class="lab-hero">
      <div class="lab-hero__grid"></div>
      <div class="lab-hero__backdrop" aria-hidden="true">
        <span class="lab-hero__ghost lab-hero__ghost--en" data-motto-ghost-en>{todayMotto.en}</span>
        <span class="lab-hero__ghost lab-hero__ghost--zh" data-motto-ghost-zh>{todayMotto.zh}</span>
      </div>

      <div class="lab-hero__content">
        <p class="lab-hero__eyebrow" data-motto-day>
          {todayMotto.dayEn.toUpperCase()} · {todayMotto.dayZh}
        </p>

        <div class="lab-hero__headline">
          <div class="lab-hero__en" data-motto-en>
            {splitMottoWords(todayMotto.en).map((word) => <span>{word}</span>)}
          </div>

          <div class="lab-hero__zh" data-motto-zh>
            {splitChineseMotto(todayMotto.zh).map((part) => <span>{part}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="lab-stage lab-stage--journal" data-lab-stage>
      <div class="lab-stage__surface">
        <div class="lab-section-heading">
          <div>
            <p class="lab-section-heading__eyebrow">01 · JOURNAL</p>
            <h2>最近更新的三篇文章</h2>
          </div>
        </div>

        <div class="lab-article-grid">
          {latestPosts.map((post) => (
            <a class="lab-article-card" href={withBasePath(getPostHref(post))}>
              <div class="lab-article-card__media">
                {post.data.cover ? (
                  <img
                    class="lab-article-card__cover"
                    src={withBasePath(post.data.cover)}
                    alt={post.data.title}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="lab-article-card__fallback">
                    <span>{post.data.category}</span>
                    <p>{post.data.tags.slice(0, 2).join(" / ") || post.data.description}</p>
                  </div>
                )}
              </div>
              <div class="lab-article-card__body">
                <div class="lab-article-card__meta">
                  <span>{post.data.category}</span>
                  <span>更新 {formatDate(getUpdatedDate(post))}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {latestInspiration && LatestInspirationContent && (
      <section class="lab-stage lab-stage--spark" data-lab-stage>
        <div class="lab-stage__surface">
          <div class="lab-section-heading lab-section-heading--compact">
            <div>
              <p class="lab-section-heading__eyebrow">02 · SPARK</p>
              <h2>最新灵感</h2>
            </div>
            <a class="lab-section-heading__all" href={withBasePath("/daily/")}>ALL</a>
          </div>

          <div class="lab-spark">
            <div class="lab-spark__island">
              <span class="lab-spark__theme">{latestInspiration.data.theme}</span>
              <span class="lab-spark__title">{latestInspiration.data.title}</span>
            </div>

            <div class="lab-spark__panel">
              <div class="lab-spark__content prose prose--inspiration">
                <LatestInspirationContent />
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="lab-topic-section">
      <div class="lab-section-heading">
        <div>
          <p class="lab-section-heading__eyebrow">03 · TOPIC MATRIX</p>
          <h2>按主题进入</h2>
        </div>
      </div>

      <CategoryGrid topics={topicTiles} />
    </section>

    <section class="lab-about-section">
      <div class="lab-section-heading">
        <div>
          <p class="lab-section-heading__eyebrow">04 · ABOUT</p>
          <h2>{siteConfig.author.name}</h2>
        </div>
      </div>

      <div class="lab-about-card">
        <div class="lab-about-card__image-wrap">
          <img
            class="lab-about-card__image"
            src={withBasePath(siteConfig.author.portrait)}
            alt={`${siteConfig.author.name} 的照片`}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="lab-about-card__content">
          <p class="lab-about-card__lead">{siteConfig.author.shortBio}</p>
          <p>{siteConfig.author.bio}</p>
        </div>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ weeklyMottos }}>
    const getMondayFirstIndex = (day) => (day + 6) % 7;
    const splitChineseMotto = (value) => {
      const normalized = value.trim();
      const parts = normalized
        .split(/[，、；]/)
        .map((part) => part.trim())
        .filter(Boolean);

      if (parts.length > 1) {
        return parts;
      }

      if (normalized.length <= 4) {
        const midpoint = Math.ceil(normalized.length / 2);
        return [normalized.slice(0, midpoint), normalized.slice(midpoint)].filter(Boolean);
      }

      if (normalized.length <= 6) {
        return [normalized.slice(0, 3), normalized.slice(3)].filter(Boolean);
      }

      return [normalized];
    };

    const today = weeklyMottos[getMondayFirstIndex(new Date().getDay())];
    const dayNode = document.querySelector("[data-motto-day]");
    const enNode = document.querySelector("[data-motto-en]");
    const zhNode = document.querySelector("[data-motto-zh]");
    const ghostEnNode = document.querySelector("[data-motto-ghost-en]");
    const ghostZhNode = document.querySelector("[data-motto-ghost-zh]");

    if (today && dayNode && enNode && zhNode && ghostEnNode && ghostZhNode) {
      dayNode.textContent = `${today.dayEn.toUpperCase()} · ${today.dayZh}`;
      enNode.replaceChildren(
        ...today.en.split(/\s+/).filter(Boolean).map((word) => {
          const span = document.createElement("span");
          span.textContent = word;
          return span;
        }),
      );
      zhNode.replaceChildren(
        ...splitChineseMotto(today.zh).map((part) => {
          const span = document.createElement("span");
          span.textContent = part;
          return span;
        }),
      );
      ghostEnNode.textContent = today.en;
      ghostZhNode.textContent = today.zh;
    }

    const stages = Array.from(document.querySelectorAll("[data-lab-stage]"));
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reducedMotion && stages.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            entry.target.classList.toggle("is-active", entry.isIntersecting && entry.intersectionRatio > 0.22);
          });
        },
        {
          threshold: [0.18, 0.22, 0.34, 0.52],
          rootMargin: "0px 0px -10% 0px",
        },
      );

      stages.forEach((stage) => observer.observe(stage));
    } else {
      stages.forEach((stage) => stage.classList.add("is-active"));
    }
  </script>
</BaseLayout>
