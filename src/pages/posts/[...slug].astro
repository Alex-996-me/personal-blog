---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getCategoryHref,
  getPostSlug,
  getUpdatedDate,
  getYoutubeEmbedUrl,
} from "../../lib/blog";
import { withBasePath } from "../../lib/paths";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const youtubeEmbedUrl = getYoutubeEmbedUrl(post.data.youtube);
const updated = getUpdatedDate(post);
const categoryHref = withBasePath(getCategoryHref(post.data.category));
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.cover}
  bodyClass="body--post"
>
  <article>
    <a class="post-backlink" href={categoryHref}>← 返回{post.data.category}</a>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(post.data.date)}</span>
        <span>最后更新：{formatDate(updated)}</span>
        <a href={categoryHref}>{post.data.category}</a>
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="标签">
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    {youtubeEmbedUrl && (
      <div class="video-embed">
        <iframe
          src={youtubeEmbedUrl}
          title={`${post.data.title} YouTube 视频`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
