---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getCategoryHref, getYoutubeEmbedUrl } from "../../lib/blog";
import {
  getChangeLogSummary,
  getCompareHrefFromSlug,
  getHistoryHrefFromSlug,
  getPostSlug,
  getUpdatedDate,
  getVersionNumber,
  getVersionTimeline,
} from "../../lib/postVersions";
import { withBasePath } from "../../lib/paths";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const youtubeEmbedUrl = getYoutubeEmbedUrl(post.data.youtube);
const slug = getPostSlug(post);
const version = getVersionNumber(post);
const updated = getUpdatedDate(post);
const timeline = await getVersionTimeline(post);
const hasPreviousVersion = timeline.some((entry) => entry.version === version - 1);
const currentSummary = getChangeLogSummary(post, version);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.cover}
>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(post.data.date)}</span>
        <span>最后更新：{formatDate(updated)}</span>
        <span>当前版本：v{version}</span>
        <a href={withBasePath(getCategoryHref(post.data.category))}>{post.data.category}</a>
      </div>
      {version > 1 && (
        <div class="version-card">
          <p class="version-card__title">本次更新</p>
          {currentSummary.length > 0 && (
            <ul class="version-summary">
              {currentSummary.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
          <div class="version-links">
            <a href={withBasePath(getHistoryHrefFromSlug(slug))}>查看更新记录</a>
            <a href={withBasePath(getHistoryHrefFromSlug(slug))}>查看历史版本</a>
            {hasPreviousVersion && (
              <a href={withBasePath(getCompareHrefFromSlug(slug, version - 1, version))}>
                查看与上一版差异
              </a>
            )}
          </div>
        </div>
      )}
      {post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="标签">
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    {youtubeEmbedUrl && (
      <div class="video-embed">
        <iframe
          src={youtubeEmbedUrl}
          title={`${post.data.title} YouTube 视频`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}

    {post.data.cover && (
      <img class="post-cover" src={withBasePath(post.data.cover)} alt={post.data.title} />
    )}

    <div class="prose">
      <Content />
    </div>

    {version > 1 && (
      <footer class="post-footer-links">
        <a href={withBasePath(getHistoryHrefFromSlug(slug))}>查看更新记录</a>
        <a href={withBasePath(getHistoryHrefFromSlug(slug))}>查看历史版本</a>
        {hasPreviousVersion && (
          <a href={withBasePath(getCompareHrefFromSlug(slug, version - 1, version))}>
            查看与上一版差异
          </a>
        )}
      </footer>
    )}
  </article>
</BaseLayout>
