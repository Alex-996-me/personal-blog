---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { formatDate, getYoutubeEmbedUrl } from "../../../../lib/blog";
import {
  getPostHrefFromSlug,
  getUpdatedDate,
  getVersionNumber,
  getVersionSlug,
} from "../../../../lib/postVersions";
import { withBasePath } from "../../../../lib/paths";

export async function getStaticPaths() {
  const versions = await getCollection("postVersions");
  return versions.map((entry) => ({
    params: {
      slug: getVersionSlug(entry),
      version: `v${getVersionNumber(entry)}`,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = getVersionSlug(entry);
const version = getVersionNumber(entry);
const youtubeEmbedUrl = getYoutubeEmbedUrl(entry.data.youtube);
---

<BaseLayout
  title={`${entry.data.title} · 历史版本 v${version}`}
  description={`${entry.data.title} 的历史版本 v${version}`}
>
  <div class="version-note">
    你正在阅读历史版本 v{version}，这不是最新版。
    <a href={withBasePath(getPostHrefFromSlug(slug))}>返回最新版</a>
  </div>

  <article>
    <header class="post-header">
      <h1>{entry.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(entry.data.date)}</span>
        <span>最后更新：{formatDate(getUpdatedDate(entry))}</span>
        <span>版本号：v{version}</span>
      </div>
    </header>

    {youtubeEmbedUrl && (
      <div class="video-embed">
        <iframe
          src={youtubeEmbedUrl}
          title={`${entry.data.title} YouTube 视频`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}

    {entry.data.cover && (
      <img class="post-cover" src={withBasePath(entry.data.cover)} alt={entry.data.title} />
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
