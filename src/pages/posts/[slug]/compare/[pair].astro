---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { formatDate } from "../../../../lib/blog";
import { renderDiffHtml } from "../../../../lib/diff";
import {
  getVersionComparePairs,
} from "../../../../lib/postVersions";
import { withBasePath } from "../../../../lib/paths";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const paths = [];

  for (const post of posts) {
    const pairs = await getVersionComparePairs(post);
    for (const pair of pairs) {
      paths.push({
        params: {
          slug: pair.slug,
          pair: `v${pair.from.version}-v${pair.to.version}`,
        },
        props: { post, pair },
      });
    }
  }

  return paths;
}

const { post, pair } = Astro.props;
const diffHtml = renderDiffHtml(pair.from.body, pair.to.body);
---

<BaseLayout
  title={`${post.data.title} · 版本对比 v${pair.from.version} → v${pair.to.version}`}
  description={`${post.data.title} 的版本差异对比。`}
>
  <section class="page-header">
    <h1>版本对比：v{pair.from.version} → v{pair.to.version}</h1>
    <p>{post.data.title}</p>
  </section>

  <div class="version-card">
    <div class="post-meta">
      <span>v{pair.from.version} 更新于：{formatDate(pair.from.updated)}</span>
      <span>v{pair.to.version} 更新于：{formatDate(pair.to.updated)}</span>
    </div>
    <p class="version-card__title">本次更新摘要</p>
    <ul class="version-summary">
      {(pair.to.summary.length > 0 ? pair.to.summary : ["未提供更新摘要。"]).map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <section class="diff-card">
    <div class="diff-prose" set:html={diffHtml}></div>
  </section>
</BaseLayout>
