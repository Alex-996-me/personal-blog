---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getInspirationSlug,
  getInspirationThemeHref,
  getInspirationUpdatedDate,
} from "../../lib/blog";
import { withBasePath } from "../../lib/paths";

export async function getStaticPaths() {
  const inspirations = await getCollection("inspirations");
  return inspirations
    .filter((inspiration) => inspiration.data.published !== false)
    .map((inspiration) => ({
    params: { slug: getInspirationSlug(inspiration) },
    props: { inspiration },
    }));
}

const { inspiration } = Astro.props;
const { Content } = await render(inspiration);
const updated = getInspirationUpdatedDate(inspiration);
---

<BaseLayout
  title={inspiration.data.title}
  description={inspiration.data.description}
  showSidebar={false}
  wideContent={true}
  bodyClass="body--daily"
  shellClass="page-shell--daily"
  panelClass="content-panel--daily"
>
  <article>
    <a class="post-backlink" href={withBasePath(getInspirationThemeHref(inspiration.data.theme))}>
      ← 返回 {inspiration.data.theme}
    </a>

    <header class="post-header">
      <h1>{inspiration.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(inspiration.data.date)}</span>
        <span>最后更新：{formatDate(updated)}</span>
        <span>{inspiration.data.theme}</span>
      </div>
    </header>

    <div class="prose prose--inspiration">
      <Content />
    </div>
  </article>
</BaseLayout>
