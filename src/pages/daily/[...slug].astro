---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getInspirationSlug,
  getInspirationUpdatedDate,
} from "../../lib/blog";
import { withBasePath } from "../../lib/paths";

export async function getStaticPaths() {
  const inspirations = await getCollection("inspirations");
  return inspirations
    .filter((inspiration) => inspiration.data.published !== false)
    .map((inspiration) => ({
    params: { slug: getInspirationSlug(inspiration) },
    props: { inspiration },
    }));
}

const { inspiration } = Astro.props;
const { Content } = await render(inspiration);
const updated = getInspirationUpdatedDate(inspiration);
---

<BaseLayout title={inspiration.data.title} description={inspiration.data.description}>
  <article>
    <a class="post-backlink" href={withBasePath("/daily/")}>
      ← 返回每日灵感
    </a>

    <header class="post-header">
      <h1>{inspiration.data.title}</h1>
      <div class="post-meta">
        <span>发布于：{formatDate(inspiration.data.date)}</span>
        <span>最后更新：{formatDate(updated)}</span>
        <span>每日灵感</span>
      </div>
      {inspiration.data.tags.length > 0 && (
        <div class="tag-list" aria-label="灵感标签">
          {inspiration.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose--inspiration">
      <Content />
    </div>
  </article>
</BaseLayout>
